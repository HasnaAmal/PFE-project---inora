generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ✅ renamed to match what Conversation model uses
enum Status {
  OPEN
  CLOSED
}

model User {
  id                String             @id @default(cuid())
  fullName          String
  email             String             @unique
  password          String
  role              String             @default("member")
  suspended         Boolean            @default(false)
  avatarUrl         String?
  createdAt         DateTime           @default(now())
  gatheringRequests GatheringRequest[]
  drafts            Draft[]
  reviews           Review[]
  conversations     Conversation[]     @relation("UserConversations")
  claimedConvos     Conversation[]     @relation("ClaimedConversations") // ✅ added
  sentMessages      Message[]          @relation("SentMessages")
}

model GatheringRequest {
  id              String    @id @default(cuid())
  userId          String
  occasion        String
  activity        String
  guestCount      Int
  preferredDate   DateTime
  alternateDate   DateTime?
  location        String
  duration        String
  specialRequests String?
  status          String    @default("pending")
  totalPrice      Float?
  advanceAmount   Float?
  advancePaid     Boolean   @default(false)
  remainingPaid   Boolean   @default(false)
  advancePaidAt   DateTime?
  createdAt       DateTime  @default(now())
  user            User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  review          Review?
}

model Draft {
  id          String   @id @default(cuid())
  userId      String
  formData    Json
  lastSavedAt DateTime @updatedAt
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Review {
  id                 String            @id @default(cuid())
  userId             String
  gatheringRequestId String?           @unique
  comment            String
  rating             Int
  approved           Boolean           @default(false)
  createdAt          DateTime          @default(now())
  user               User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  gatheringRequest   GatheringRequest? @relation(fields: [gatheringRequestId], references: [id])
}

model Conversation {
  id           Int       @id @default(autoincrement())
  userId       String                              // ✅ String to match User.id (cuid)
  user         User      @relation("UserConversations", fields: [userId], references: [id])
  subject      String?
  status       Status    @default(OPEN)            // ✅ matches enum name
  claimedById  String?                             // ✅ String to match User.id (cuid)
  claimedBy    User?     @relation("ClaimedConversations", fields: [claimedById], references: [id])
  messages     Message[]
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  senderId       String
  sender         User         @relation("SentMessages", fields: [senderId], references: [id])
  body           String
  createdAt      DateTime     @default(now())
  readAt         DateTime?
}
